Host *
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null

Host password-auth-match
    HostName 172.31.0.21
    User demo

Host key-auth-match
    HostName 172.31.0.22
    User demo
    IdentityFile ~/.ssh/demo_lssh_ed25519

Host over-proxy-match
    HostName 172.31.1.41
    User demo
    IdentityFile ~/.ssh/demo_lssh_ed25519
    ProxyCommand ssh -i ~/.ssh/demo_lssh_ed25519 -W %h:%p demo@172.31.0.31

Match originalhost password-auth-match
    Port 22

Match user demo originalhost key-auth-match
    ForwardX11 yes
    ControlMaster auto
    ControlPersist 30s

Match localuser demo host 172.31.1.41
    LocalCommand printf "demo-match:%n -> %h:%p\n"
